### 9c. Relaxation time estimation
def estimate_tau(G_t0, G_t1, eps_t0, eps_t1,
                 delta_t_days, shell_mask):
    """
    From two serial FNO predictions, estimate tissue relaxation time τ.
    Assumes single-exponential: ε(t) = ε₀ · exp(-t/τ)

    Returns τ in days. Returns None if signal too weak to estimate.
    """
    eps_ring_t0 = eps_t0[shell_mask].mean()
    eps_ring_t1 = eps_t1[shell_mask].mean()

    if eps_ring_t0 < 1e-4 or eps_ring_t1 < 1e-4:
        return None

    tau = -delta_t_days / np.log(eps_ring_t1 / eps_ring_t0 + 1e-10)
    return max(tau, 0)

### 9d. Acoustoelastic constant recovery
def recover_acoustoelastic_constant(G_pred, eps_pred,
                                     G_bg_mean, shell_mask):
    """
    Recover A from: G_eff = G_bg + A · ε_latent
    Fit by least squares in the perilesional shell.
    Target: recovered A within 20% of ground truth A.
    """
    eps_ring = eps_pred[shell_mask]
    dG_ring  = G_pred[shell_mask] - G_bg_mean
    A_fit    = np.linalg.lstsq(
                   eps_ring[:,None], dG_ring, rcond=None)[0][0]
    return A_fit

### 9e. Stratified evaluation table
Evaluate all metrics split by:
    - Expansion pressure bin: [0], [500-2000], [2000-5000], [5000-8000] Pa
    - Contrast ratio: G_lesion/G_bg in [1-3], [3-7], [7-15]
    - Lesion size: a_eq in [small <10mm], [medium 10-20mm], [large >20mm]

