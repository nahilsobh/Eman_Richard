Layer 2 — Model Quality Check
Run after training completes (100 epochs). Takes 10 minutes.
2a. Loss curve inspection

# scripts/plot_training.py
import json, matplotlib.pyplot as plt

h = json.load(open("runs/phase0/history.json"))

fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(10, 4))
ax1.plot(h["train_loss"], label="train")
ax1.plot(h["val_rl2"],    label="val RL²")
ax1.axhline(0.05, color="red", linestyle="--", label="target")
ax1.set_title("Relative L² loss")
ax1.legend()

ax2.plot(h["val_ssim"])
ax2.axhline(0.90, color="red", linestyle="--", label="target SSIM=0.90")
ax2.set_title("Validation SSIM")
ax2.legend()

plt.savefig("runs/phase0/training_curves.png", dpi=150)


What you are looking for:

Val RL² should drop below 0.10 by epoch 30 and settle below 0.05 by epoch 80
Val SSIM should exceed 0.85
Train and val curves should track each other — a large gap means overfitting to the simulation distribution
No sudden spikes (which indicate CFL violations leaking into the solver)


2b. The benchmark figure — most important check

# scripts/benchmark_figure.py
import torch, h5py, numpy as np, matplotlib.pyplot as plt
from src.fno_model import FNO2d

model = FNO2d()
ckpt  = torch.load("runs/phase0/best.pt", map_location="cpu")
model.load_state_dict(ckpt["model_state"])
model.eval()

f = h5py.File("data/mre_synthetic_50000.h5", "r")

# Pick 6 test cases that span the stiffness contrast range
test_ids = [45000, 45200, 45500, 46000, 47000, 48000]

fig, axes = plt.subplots(6, 3, figsize=(9, 18))

for row, idx in enumerate(test_ids):
    X = torch.tensor(f["X"][idx:idx+1])
    Y_true = f["Y"][idx]

    with torch.no_grad():
        Y_pred = model(X).squeeze().numpy()

    rl2 = np.linalg.norm(Y_pred - Y_true) / np.linalg.norm(Y_true)
    vmin, vmax = Y_true.min(), Y_true.max()

    axes[row,0].imshow(X[0,0], cmap="RdBu_r")
    axes[row,0].set_title("Re(u) — input" if row==0 else "")

    axes[row,1].imshow(Y_pred, cmap="hot", vmin=vmin, vmax=vmax)
    axes[row,1].set_title(f"FNO prediction  RL²={rl2:.3f}" if row==0 else f"RL²={rl2:.3f}")

    axes[row,2].imshow(Y_true, cmap="hot", vmin=vmin, vmax=vmax)
    axes[row,2].set_title("Ground truth" if row==0 else "")

    for ax in axes[row]: ax.axis("off")

plt.tight_layout()
plt.savefig("runs/phase0/benchmark_figure.png", dpi=200)
print("Saved benchmark_figure.png")

This is the figure you email to Dr. Ehman. What you are looking for visually:

Inclusion boundaries should be sharp in the prediction, not blurry
The prediction should not "leak" stiffness into the background
Cases with high contrast (G_inc / G_bg > 10) should look as clean as low contrast cases

